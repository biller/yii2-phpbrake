{
  "name": "biller/yii2-phpbrake",
  "description": "Yii2 PHPBrake integration",
  "keywords": [
    "yii2",
    "extension",
    "airbrake",
    "error",
    "reporting",
    "logging"
  ],
  "homepage": "https://github.com/biller/yii2-phpbrake",
  "type": "yii2-extension",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/biller/yii2-phpbrake/issues",
    "source": "https://github.com/biller/yii2-phpbrake"
  },
  "minimum-stability": "stable",
  "require": {
    "php": "^7.0 || ^8.0",
    "airbrake/phpbrake": "^1.0",
    "yiisoft/yii2": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "biller\\phpbrake\\": "src"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true
  }
}
